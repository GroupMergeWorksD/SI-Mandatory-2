          "raw": "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<soapenv:Envelope xmlns:soapenv=\"http://schemas.xmlsoap.org/soap/envelope/\"\n                  xmlns:res=\"http://groupmergeworks.com/sirmeows/equipment-reservation-soap-api\">\n   <soapenv:Header/>\n   <soapenv:Body>\n      <res:createReservationRequest>\n         <res:equipmentId>{{availableEquipmentId}}</res:equipmentId>\n         <res:startTime>{{validStartTime}}</res:startTime>\n         <res:endTime>{{validEndTime}}</res:endTime>\n      </res:createReservationRequest>\n   </soapenv:Body>\n</soapenv:Envelope>"
        }
