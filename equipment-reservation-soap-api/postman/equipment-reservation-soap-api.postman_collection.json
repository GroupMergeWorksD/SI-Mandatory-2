  "item": [
    {
      "name": "create-reservation-success",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"returns HTTP 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"returns reservation data\", function () {",
              "    const body = pm.response.text();",
              "    pm.expect(body).to.match(/<[^>]*:?reservationId>/);",
              "    pm.expect(body).to.include(pm.collectionVariables.get(\"availableEquipmentId\"));",
              "    pm.expect(body).to.include(\"2026-06-10T09:00:00\");",
              "    pm.expect(body).to.include(\"2026-06-10T11:00:00\");",
              "    pm.expect(body).to.not.include(\"<SOAP-ENV:Fault>\");",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "text/xml; charset=utf-8"
          },
          {
            "key": "Accept",
            "value": "text/xml"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/ws",
          "host": [
